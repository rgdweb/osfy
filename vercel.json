{
  "crons": [
    {
      "path": "/api/cron/processar-faturas?secret=${CRON_SECRET}",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/whatsapp/lembretes?secret=${CRON_SECRET}",
      "schedule": "0 9,18 * * *"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, must-revalidate" }
      ]
    }
  ]
}
